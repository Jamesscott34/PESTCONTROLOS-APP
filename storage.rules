rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 1) Reports: keep your current behavior (auth required)
    match /Reports/{reportNum}/{allPaths=**} {
      allow read, write, create: if request.auth != null;
    }

    // 2) Public read for JSON files under the folder named "grpc pricing"
    //    We match the second segment as {fileName} (no .json in the path),
    //    then enforce the extension via a condition.
    match /{folder}/{fileName} {
      allow read: if folder == "grpc pricing"
                  && fileName.matches('.*\\.json');

      allow write, create: if request.auth != null
                           && folder == "grpc pricing"
                           && fileName.matches('.*\\.json');
    }

    // 3) Everything else: keep your original default (auth required)
    match /{allPaths=**} {
      allow read, write, create: if request.auth != null;
    }
  }
}
