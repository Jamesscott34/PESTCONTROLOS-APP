rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Reports folders (Reports25/January/file.pdf etc.)
    match /Reports/{reportNum}/{allPaths=**} {
      allow read, write, create: if request.auth != null;
    }

    // Contract-linked auto uploads (contracts/{contractId}/file.pdf)
    match /contracts/{allPaths=**} {
      allow read, write, create: if request.auth != null;
    }

    // Public JSON pricing/config fetches; writes still require auth.
    match /{folder}/{fileName} {
      allow read: if (folder == "grpc pricing" || folder == "demo pricing")
                  && fileName.matches('.*\\.json');

      allow write, create: if request.auth != null
                           && (folder == "grpc pricing" || folder == "demo pricing")
                           && fileName.matches('.*\\.json');
    }

    // Keep the remaining authenticated storage behavior identical across CRM + GRPC.
    match /{allPaths=**} {
      allow read, write, create: if request.auth != null;
    }
  }
}
