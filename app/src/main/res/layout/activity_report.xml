<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:fitsSystemWindows="true">

    <!-- ✅ Only one direct child: outer LinearLayout -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <!-- Spacer for notch/status bar -->
        <View
            android:id="@+id/statusSpacer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent" />

        <!-- Welcome Message -->
        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Report"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Report form choice: Default or Select template (visible when opened via Create Custom Report) -->
        <LinearLayout
            android:id="@+id/reportFormChoiceSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Report form"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <Button
                    android:id="@+id/reportFormDefaultButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Default"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/reportFormSelectTemplateButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Select template..."
                    android:layout_marginStart="4dp"
                    android:backgroundTint="?attr/colorSecondary"
                    android:textColor="?attr/colorOnSecondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Fixed report body (used when no template selected). Template-based report uses dynamicTemplateContainer. -->
        <LinearLayout
            android:id="@+id/reportBodyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Client &amp; Visit"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:textColor="?android:attr/textColorPrimary" />

            <!-- Input field for property name -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- Input field for address -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/addressInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- Date and Time -->
            <EditText
                android:id="@+id/dateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/edit_text_border"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary"/>

            <!-- Visit type -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/visitTypeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Service report"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                android:textColor="?android:attr/textColorPrimary" />

            <!-- Site inspection -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/siteInspectionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- Recommendations -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/recommendationsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Next steps"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                android:textColor="?android:attr/textColorPrimary" />

            <!-- Prep steps -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/prepInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- Follow up -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/followUpInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- Technician name -->
            <com.grpc.grpc.DictateEditText
                android:id="@+id/techInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

        <!-- Dynamic template body: header+field pairs when a saved template is selected. Initially empty and hidden. -->
        <LinearLayout
            android:id="@+id/dynamicTemplateContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Password protect PDF (same as Action Form) -->
        <CheckBox
            android:id="@+id/passwordProtectCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:padding="12dp"
            android:text="Password protect PDF (require password to edit)"
            android:textSize="14sp"
            android:checked="false"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Image button -->
        <Button
            android:id="@+id/selectImageButton"
            android:text="Add Image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>

        <!-- Read Back button -->
        <Button
            android:id="@+id/readBackButton"
            android:text="📖 Read Report Back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="?attr/colorSecondary"
            android:textColor="?attr/colorOnSecondary"/>

        <!-- AI Fix: only visible when logged in (offline users must not see this) -->
        <Button
            android:id="@+id/aiFixButton"
            android:text="✏️ AI Fix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"/>

        <!-- PDF Template section: only visible when user is NOT logged in (offline). When logged in this is hidden. -->
        <LinearLayout
            android:id="@+id/pdfTemplateSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PDF Template"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:textColor="?android:attr/textColorPrimary" />
            <RadioGroup
                android:id="@+id/templateSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <RadioButton
                    android:id="@+id/radioGrpcTemplate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use GRPC Template"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/radioMyTemplate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Use My Template" />
            </RadioGroup>
            <Button
                android:id="@+id/pdfTemplateSettingsButton"
                android:text="PDF Template Settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:backgroundTint="?attr/colorSecondary"
                android:textColor="?attr/colorOnSecondary" />
        </LinearLayout>

        <!-- General Quotation (catalog-driven) -->
        <Button
            android:id="@+id/generalQuotationButton"
            android:text="@string/general_quotation_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

        <!-- Save button -->
        <Button
            android:id="@+id/saveButton"
            android:text="Save Report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"/>

        <!-- Back button -->
        <Button
            android:id="@+id/backButton"
            android:text="Back to Main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingBottom="32dp"
            android:backgroundTint="?attr/colorError"
            android:textColor="?attr/colorOnError"/>

    </LinearLayout>
</ScrollView>
