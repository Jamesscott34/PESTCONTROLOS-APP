<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize"
    android:fillViewport="true"
    android:padding="16dp"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- ✅ Only one child inside ScrollView -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Spacer must be inside the LinearLayout -->
        <View
            android:id="@+id/statusSpacer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:text="@string/custom_quotation_title"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Input Fields -->
        <EditText
            android:id="@+id/companyNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Company Name"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/addressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Company Address"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <!-- Tech email/number: hidden, autofilled from session -->
        <EditText
            android:id="@+id/userEmailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:hint="User Email"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/mobileNumberInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:hint="Mobile Number"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VAT rate"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorPrimary" />

        <RadioGroup
            android:id="@+id/vatRateGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <RadioButton
                android:id="@+id/vat13_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="13.5%" />
            <RadioButton
                android:id="@+id/vat23"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="23%" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/check30PercentDeposit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30% Deposit Required"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/check50PercentDeposit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="50% Deposit Required"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/quoteDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quote BreakDown"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/itemDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item Breakdown"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/itemPriceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item Price (€)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <Button
            android:id="@+id/addItemButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="ADD LINE ITEM"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Images (optional)"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorPrimary" />

        <Button
            android:id="@+id/addImageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Add image"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

        <HorizontalScrollView
            android:id="@+id/imagesScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/imagesContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <CheckBox
            android:id="@+id/passwordProtectCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:text="Password protect PDF (require password to edit)"
            android:textSize="14sp"
            android:checked="false"
            android:textColor="?android:attr/textColorPrimary" />

        <include layout="@layout/include_report_signature_buttons" />

        <Button
            android:id="@+id/previewPdfButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="PREVIEW QUOTATION PDF"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

        <Button
            android:id="@+id/generatePdfButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="GENERATE QUOTATION PDF"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />
    </LinearLayout>
</ScrollView>
