<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize"
    android:fillViewport="true"
    android:padding="16dp"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- ✅ Only one child inside ScrollView -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Spacer must be inside the LinearLayout -->
        <View
            android:id="@+id/statusSpacer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:text="Welcome!"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Input Fields -->
        <EditText
            android:id="@+id/companyNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Company Name"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/companyAddressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Company Address"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/addressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Customer Address"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/userEmailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="User Email"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/mobileNumberInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mobile Number"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/quoteDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quote BreakDown"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/itemDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item Breakdown"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/itemPriceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item Price (€)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <Button
            android:id="@+id/addItemButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Line Item" />

        <Button
            android:id="@+id/generatePdfButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate Quotation PDF" />
    </LinearLayout>
</ScrollView>
