<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" 
    xmlns:app="http://schemas.android.com/apk/res-auto" 
    android:layout_width="match_parent" 
    android:layout_height="match_parent" 
    android:paddingTop="?attr/actionBarSize" 
    android:fillViewport="true" 
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- ✅ Only ONE direct child inside ScrollView -->
    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="wrap_content" 
        android:orientation="vertical" 
        android:gravity="center" 
        android:padding="16dp">

        <!-- Spacer for status bar or notch -->
        <View 
            android:id="@+id/statusSpacer" 
            android:layout_width="match_parent" 
            android:layout_height="?attr/actionBarSize" 
            android:background="@android:color/transparent"/>

        <!-- Logo -->
        <ImageView
            android:id="@+id/loginLogo"
            android:layout_width="120dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/logo"
            android:contentDescription="GRPC Logo" />

        <!-- Email input -->
        <EditText 
            android:id="@+id/emailEditText" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:hint="Email" 
            android:inputType="textEmailAddress" 
            android:layout_marginBottom="16dp" 
            android:textSize="18sp" 
            android:padding="12dp" 
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"/>

        <!-- Password input -->
        <EditText 
            android:id="@+id/passwordEditText" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:hint="Password" 
            android:inputType="textPassword" 
            android:layout_marginBottom="24dp" 
            android:textSize="18sp" 
            android:padding="12dp" 
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"/>

        <!-- Login button -->
        <Button 
            android:id="@+id/loginButton" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:text="Login" 
            android:layout_marginBottom="12dp" 
            android:textSize="20sp" 
            android:padding="14dp" 
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"/>

        <!-- Offline login: use app without Firebase (e.g. custom PDF template only) -->
        <Button 
            android:id="@+id/offlineLoginButton" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:text="Offline login" 
            android:layout_marginBottom="12dp" 
            android:textSize="18sp" 
            android:padding="14dp" 
            android:backgroundTint="?attr/colorSecondary"
            android:textColor="?attr/colorOnSecondary"/>

    </LinearLayout>
</ScrollView>
