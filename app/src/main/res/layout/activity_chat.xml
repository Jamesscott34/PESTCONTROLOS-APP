<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:background="@android:color/transparent" />

    <!-- Header row: title + optional admin settings icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🤖 AI Chat"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Admin-only: Update API Key (visibility set in ChatActivity via role) -->
        <ImageButton
            android:id="@+id/chatAdminSettingsButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:contentDescription="Update API Key (admin)" />
    </LinearLayout>

    <!-- Messages ScrollView -->
    <ScrollView
        android:id="@+id/messagesScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/colorSurface"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/messagesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <!-- Mode Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/pestControlModeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🐛 Pest Control Expert"
            android:layout_marginEnd="4dp"
            android:backgroundTint="?attr/colorSecondary"
            android:textColor="?attr/colorOnSecondary" />

        <Button
            android:id="@+id/generalModeButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌍 General AI"
            android:layout_marginStart="4dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

    </LinearLayout>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type your message..."
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:inputType="textMultiLine"
            android:maxLines="4" />

        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/colorSurface"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Voice Input" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"
            android:minWidth="80dp" />

    </LinearLayout>

    <!-- Read Back Button -->
    <Button
        android:id="@+id/readBackButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📖 Read Back Last AI Response"
        android:backgroundTint="?attr/colorSecondary"
        android:textColor="?attr/colorOnSecondary"
        android:layout_marginBottom="8dp" />

    <!-- Delete Button -->
    <Button
        android:id="@+id/deleteButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑️ Delete All Messages"
        android:backgroundTint="?attr/colorError"
        android:textColor="?attr/colorOnError" />

</LinearLayout> 