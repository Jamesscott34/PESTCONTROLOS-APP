<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:paddingTop="?attr/actionBarSize"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <!-- ✅ One direct child only -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top Spacer (now correctly nested) -->
        <View
            android:id="@+id/statusSpacer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent" />

        <!-- Company / customer details -->
        <EditText
            android:id="@+id/companyNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Company Name (customer)"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="?attr/colorSurface"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/addressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Customer Address"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="?attr/colorSurface"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/quoteDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quotation Breakdown"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/colorSurface"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <!-- Materials Required section (table-like, above totals) -->
        <TextView
            android:id="@+id/materialsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Materials Required"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorPrimary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/materialsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/addMaterialButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Material Item"
            android:backgroundTint="?attr/colorSecondary"
            android:textColor="?attr/colorOnSecondary"
            android:layout_marginBottom="16dp" />

        <!-- Company contact (auto-filled from profile) -->
        <TextView
            android:id="@+id/userEmailLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Company email (from your account)"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone" />

        <EditText
            android:id="@+id/userEmailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Loading…"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="?attr/colorSurface"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:enabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/mobileNumberLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Company number (from your account)"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone" />

        <EditText
            android:id="@+id/mobileNumberInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Loading…"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/colorSurface"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary"
            android:enabled="false"
            android:visibility="gone" />

        <!-- Quotation line items (existing breakdown, kept intact) -->
        <TextView
            android:id="@+id/quotationItemsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quotation Line Items"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <EditText
            android:id="@+id/itemDescriptionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Short quote description (for the priced line)"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="?attr/colorSurface"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/itemPriceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Full price excluding VAT"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <!-- VAT and deposit options -->
        <TextView
            android:id="@+id/vatLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VAT rate"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:id="@+id/vatOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <RadioGroup
                android:id="@+id/vatRadioGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/vat13Radio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="13.5%"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/vat23Radio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="23%" />
            </RadioGroup>
        </LinearLayout>

        <CheckBox
            android:id="@+id/check30PercentDeposit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30% Deposit Required"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="4dp" />

        <CheckBox
            android:id="@+id/check50PercentDeposit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="50% Deposit Required"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/passwordProtectCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password protect PDF (require password to edit)"
            android:textSize="14sp"
            android:checked="false"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/selectImageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attach Images (optional)"
            android:backgroundTint="?attr/colorSecondary"
            android:textColor="?attr/colorOnSecondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/addItemButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Line Item"
            android:backgroundTint="?attr/colorSecondary"
            android:textColor="?attr/colorOnSecondary"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/generatePdfButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate Bird Quotation PDFs"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

        <Button
            android:id="@+id/previewPdfButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Preview Bird Quotation PDFs"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

    </LinearLayout>
</ScrollView>
