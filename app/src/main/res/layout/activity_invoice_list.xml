<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:id="@+id/invoiceListTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/invoice_screen_list_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/button_spacing" />

    <ListView
        android:id="@+id/invoiceListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:scrollbars="vertical" />

    <Button
        android:id="@+id/buttonCreateInvoice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/invoice_screen_create_title"
        android:visibility="gone"
        android:backgroundTint="?attr/colorSecondary"
        android:textColor="?attr/colorOnSecondary" />
</LinearLayout>
