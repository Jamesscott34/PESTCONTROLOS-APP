<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/screen_padding"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imageInvoiceBrandLogo"
            android:layout_width="160dp"
            android:layout_height="72dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/invoice_field_template"
            android:scaleType="fitStart"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_screen_create_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_create_hint"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_contract_prefill"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/buttonSelectInvoiceContract"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/invoice_search_contract_button" />

        <TextView
            android:id="@+id/textSelectedInvoiceContract"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/invoice_contract_none"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_template"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/radioInvoiceTemplate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioTplInitial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/invoice_template_initial_setup" />

            <RadioButton
                android:id="@+id/radioTplMonthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/invoice_template_monthly_maintenance" />

            <RadioButton
                android:id="@+id/radioTplFeature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/invoice_template_feature_update" />

            <RadioButton
                android:id="@+id/radioTplCustom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/invoice_template_custom" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_customer_name"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editInvoiceCustomerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invoice_field_customer_name"
            android:inputType="textPersonName"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_customer_email"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editInvoiceCustomerEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invoice_field_customer_email"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_title"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editInvoiceTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invoice_field_title"
            android:inputType="textCapSentences"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_body"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editInvoiceBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invoice_field_body"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="3"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_amount"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editInvoiceAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invoice_field_amount"
            android:inputType="numberDecimal"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_vat_rate"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editInvoiceVatRate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invoice_field_vat_rate"
            android:inputType="numberDecimal"
            android:text="13.5"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textInvoiceTotalsPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/surface_frame"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_notes"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editInvoiceNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/invoice_field_notes"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="2"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/buttonGenerateInvoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/button_spacing"
            android:text="@string/invoice_create_button" />
    </LinearLayout>
</ScrollView>
