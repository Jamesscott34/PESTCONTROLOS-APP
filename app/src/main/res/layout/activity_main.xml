<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================
     GRPest Control Application - Main Activity Layout
     ============================================================================
     
     This layout defines the main navigation screen of the application.
     It provides access to all major features including:
     - Report creation and management
     - Contract and customer management
     - Job assignment and tracking
     - Quotation generation
     - Service agreements
     - Sales and commission tracking
     - Environmental risk assessments
     - Internal messaging
     - Company website access
     - Secure logout functionality
     
     Layout Structure:
     - Top spacer to avoid camera/notch coverage
     - Scrollable content area with navigation buttons
     - Fixed logout button at bottom
     - Theme-aware styling for dark/light mode support
     ============================================================================ -->

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?android:attr/colorBackground"
    android:padding="16dp"
    android:paddingTop="?attr/actionBarSize">

    <!-- ============================================================================
         TOP SPACER FOR CAMERA/NOTCH AVOIDANCE
         ============================================================================
         Ensures content doesn't get covered by device camera or notch
         ============================================================================ -->
    <View
        android:id="@+id/statusSpacer"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@android:color/transparent" />

    <!-- ============================================================================
         SCROLLABLE CONTENT AREA
         ============================================================================
         Contains all navigation buttons in a scrollable layout
         ============================================================================ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/LogoutButton">

        <!-- ============================================================================
             MAIN CONTENT CONTAINER
             ============================================================================
             Vertical layout containing all navigation buttons
             ============================================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- ============================================================================
                 WELCOME MESSAGE
                 ============================================================================
                 Personalized greeting showing user's name
                 ============================================================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="64dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/welcomeLogo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="8dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo"
                    android:contentDescription="GRPC Logo" />

                <TextView
                    android:id="@+id/welcomeTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome, User!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

            <!-- Notification history - see what notifications were received -->
            <Button
                android:id="@+id/NotificationsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:layout_marginBottom="8dp"
                android:backgroundTint="?attr/colorSecondary"
                android:textColor="?attr/colorOnSecondary" />

            <!-- Global search across Jobs/Contracts/Leads/Reports -->
            <Button
                android:id="@+id/SearchButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />



            <!-- ============================================================================
                 REPORT MANAGEMENT BUTTONS
                 ============================================================================
                 Buttons for creating and viewing pest control reports
                 ============================================================================ -->
            
            <!-- Create new pest control reports -->
            <Button
                android:id="@+id/ReportButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Report"
                android:layout_marginBottom="8dp" />

            <!-- View and manage stored reports -->
            <Button
                android:id="@+id/ReportViewButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Reports"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================================
                 WORK MANAGEMENT BUTTONS
                 ============================================================================
                 Buttons for calendar and work scheduling
                 ============================================================================ -->
            
            <!-- Work View Calendar -->
            <Button
                android:id="@+id/WorkViewButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Work View"
                android:layout_marginBottom="8dp" />

            <!-- James-only: technician last location finder -->
            <Button
                android:id="@+id/LocationFinderButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location Finder"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- ============================================================================
                 CONTRACT MANAGEMENT BUTTONS
                 ============================================================================
                 Buttons for managing pest control contracts
                 ============================================================================ -->
            
            <!-- Manage service contracts and customer relationships -->
            <Button
                android:id="@+id/ContractsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contracts"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================================
                 QUOTATION & SERVICE AGREEMENTS
                 ============================================================================
                 Buttons for generating quotes and service agreements
                 ============================================================================ -->
            
            <!-- Generate professional quotations for pest control services -->
            <Button
                android:id="@+id/GeneralQuotesButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="General Quotes"
                android:layout_marginBottom="8dp" />

            <!-- Create and manage service agreements with customers -->
            <Button
                android:id="@+id/ServiceAgreementButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Service agreement"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================================
                 SALES & COMMISSION TRACKING
                 ============================================================================
                 Button for managing sales leads and commission tracking
                 ============================================================================ -->
            
            <!-- Manage sales leads and commission calculations -->
            <Button
                android:id="@+id/CommisionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Commision"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================================
                 JOB MANAGEMENT
                 ============================================================================
                 Button for job assignment and tracking
                 ============================================================================ -->
            
            <!-- Assign and track pest control jobs -->
            <Button
                android:id="@+id/JobsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Job Work"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================================
                 ENVIRONMENTAL COMPLIANCE
                 ============================================================================
                 Button for Environmental Risk Assessments (ERA)
                 ============================================================================ -->
            
            <!-- Create Environmental Risk Assessment reports -->
            <Button
                android:id="@+id/EnviromentButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ERA"
                android:layout_marginBottom="8dp" />

            <!-- ============================================================================
                 COMMUNICATION & EXTERNAL LINKS
                 ============================================================================
                 Buttons for internal messaging and company website access
                 ============================================================================ -->
            
            <!-- Internal messaging system for staff communication -->
            <Button
                android:id="@+id/InstantMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Messaging"
                android:layout_marginBottom="8dp" />

            <!-- Access company website and resources -->
            <Button
                android:id="@+id/WebsiteButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Visit GRPC Staff"
                android:onClick="WorkWebsite"
                android:layout_marginBottom="8dp" />

            <!-- In-app help / README -->
            <Button
                android:id="@+id/HelpButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How to Use App"
                android:layout_marginBottom="8dp" />

            <!-- AI Chat Assistant
            <Button
                android:id="@+id/ChatButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤖 AI Chat Assistant"
                android:layout_marginBottom="8dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" /> -->

        </LinearLayout>
    </ScrollView>

    <!-- ============================================================================
         LOGOUT BUTTON
         ============================================================================
         Fixed positioning above bottom navigation area
         Provides secure logout functionality
         ============================================================================ -->
    <Button
        android:id="@+id/LogoutButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:backgroundTint="?attr/colorError"
        android:textColor="?attr/colorOnError"
        android:layout_marginBottom="16dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
