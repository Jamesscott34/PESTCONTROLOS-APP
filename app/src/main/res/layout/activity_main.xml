<?xml version="1.0" encoding="utf-8"?>
<!-- Main dashboard - same structure as Create Report: ScrollView > LinearLayout, section labels, 2 buttons per row -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize"
    android:padding="16dp"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:id="@+id/statusSpacer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent" />

        <!-- Header: logo, welcome, subtitle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/welcomeLogo"
                android:layout_width="@dimen/welcome_logo_size"
                android:layout_height="@dimen/welcome_logo_size"
                android:layout_marginBottom="8dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/logo"
                android:contentDescription="@string/main_logo_content_description" />

            <TextView
                android:id="@+id/welcomeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="?android:attr/textColorPrimary" />

            <TextView
                android:id="@+id/mainDashboardSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_dashboard_subtitle"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary" />
        </LinearLayout>

        <!-- QUICK ACTIONS: 2 per row -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_section_quick_actions"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/ReportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_create_report"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/ReportViewButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_view_reports"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>

        <!-- OPERATIONS: 2 per row -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_section_operations"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/WorkViewButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_work_view"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/JobsButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_job_work"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>

        <!-- BUSINESS: 2 per row -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_section_business"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/ContractsButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_contracts"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/CommisionButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_commission"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>
        <Button
            android:id="@+id/EmailButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Email"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/LocationFinderButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_location_finder"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/GeneralQuotesButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="General Quotes"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/ServiceAgreementButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="Service agreement"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/EnviromentButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="ERA"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>

        <!-- TOOLS: 2 per row -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_section_tools"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/NotificationsButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_notifications"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="?attr/colorSecondary"
                android:textColor="?attr/colorOnSecondary" />
            <Button
                android:id="@+id/InstantMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_messaging"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/DashboardButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_dashboard"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/SearchButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_search"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/MapsButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_maps"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/InvoicesButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_invoices"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <Button
                android:id="@+id/RouteButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_router"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
            <Button
                android:id="@+id/HelpButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="@string/main_button_how_to_use"
                android:textSize="14sp"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/button_background"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>

        <Button
            android:id="@+id/ConverterButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/main_button_converter"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

        <!-- SYSTEM -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_section_system"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorSecondary" />

        <Button
            android:id="@+id/EmployeeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/main_button_employee"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary" />

        <!-- Logout -->
        <Button
            android:id="@+id/LogoutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/main_button_logout"
            android:textSize="14sp"
            android:backgroundTint="?attr/colorError"
            android:textColor="?attr/colorOnError"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="@dimen/logout_margin_bottom"
            android:elevation="8dp" />

    </LinearLayout>
</ScrollView>
