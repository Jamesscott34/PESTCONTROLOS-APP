<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize"
    android:fillViewport="true"
    android:padding="16dp"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/statusSpacer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_quotation_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <EditText
            android:id="@+id/customerNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/general_quotation_customer_name_hint"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/customerAddressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/general_quotation_customer_address_hint"
            android:minLines="2"
            android:gravity="top"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/dateInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/general_quotation_date_hint"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_quotation_issue_hint"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:textColor="?android:attr/textColorSecondary" />
        <Spinner
            android:id="@+id/issueSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border" />

        <EditText
            android:id="@+id/descriptionShortInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/general_quotation_description_hint"
            android:minLines="1"
            android:maxLines="2"
            android:inputType="textCapSentences"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <EditText
            android:id="@+id/basePriceInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/general_quotation_base_price_hint"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <Button
            android:id="@+id/addSecondIssueButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_quotation_add_second_issue"
            android:layout_marginBottom="12dp"
            android:backgroundTint="?attr/colorSecondary"
            android:textColor="?attr/colorOnSecondary" />

        <LinearLayout
            android:id="@+id/secondIssueSection"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/general_quotation_issue_2_hint"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"
                android:textColor="?android:attr/textColorSecondary" />
            <Spinner
                android:id="@+id/issueSpinner2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:padding="12dp"
                android:background="@drawable/edit_text_border" />
            <EditText
                android:id="@+id/basePriceInput2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/general_quotation_base_price_2_hint"
                android:inputType="numberDecimal"
                android:layout_marginBottom="8dp"
                android:padding="12dp"
                android:background="@drawable/edit_text_border"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorSecondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/vatLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_quotation_vat_label"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary" />
        <TextView
            android:id="@+id/vatValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/totalLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_quotation_total_label"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary" />
        <TextView
            android:id="@+id/totalValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <EditText
            android:id="@+id/additionalInfoInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/general_quotation_additional_info_hint"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/edit_text_border"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorSecondary" />

        <CheckBox
            android:id="@+id/passwordProtectCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Password protect PDF"
            android:textColor="?android:attr/textColorPrimary" />

        <Button
            android:id="@+id/generatePdfButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_quotation_generate_pdf" />
    </LinearLayout>
</ScrollView>
