<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- 8pt Contact Button -->
    <Button
        android:id="@+id/button8ptContact"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="8pt Contact"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- 6pt Contract Button -->
    <Button
        android:id="@+id/button6ptContract"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="6pt Contract"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/button8ptContact"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- 4pt Contract Button -->
    <Button
        android:id="@+id/button4ptContract"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4pt Contract"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/button6ptContract"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
