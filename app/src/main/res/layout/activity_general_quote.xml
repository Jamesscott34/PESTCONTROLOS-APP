<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:paddingTop="?attr/actionBarSize"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/quotesMenuContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quotes_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/quotesSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quotes_subtitle"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- Centered grid: 2x2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <Button
                    android:id="@+id/button4ptContract"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"
                    android:text="@string/quotes_4_part"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/button6ptContract"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"
                    android:text="@string/quotes_6_part"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <Button
                    android:id="@+id/button8ptContact"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"
                    android:text="@string/quotes_8_part"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/button12ptContract"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"
                    android:text="@string/quotes_12_part"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="24dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
