<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:paddingTop="?attr/actionBarSize"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/quotesMenuContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contract Quotations"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <Button
            android:id="@+id/button8ptContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="8pt Contract"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/button6ptContract"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="6pt Contract"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/button4ptContract"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="4pt Contract"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/button12ptContract"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="12pt Contract"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
