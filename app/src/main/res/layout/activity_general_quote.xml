<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:paddingTop="?attr/actionBarSize"
    android:background="?android:attr/colorBackground">

    <!-- Centered content -->
    <LinearLayout
        android:id="@+id/quotesMenuContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, User!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <Button
            android:id="@+id/button8ptContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8pt Contact"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/button6ptContract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6pt Contract"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/button4ptContract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4pt Contract"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/button12ptContract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12pt Contract"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
