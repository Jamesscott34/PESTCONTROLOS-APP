<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:paddingTop="?attr/actionBarSize"
    android:fitsSystemWindows="true">

    <!-- Top Spacer to avoid notch -->
    <View
        android:id="@+id/statusSpacer"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent" />

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?attr/colorSurface">

        <!-- Welcome Message -->
        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Work View"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- View Toggle Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="?attr/colorSurface">

            <Button
                android:id="@+id/dailyViewButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Daily"
                android:layout_marginEnd="4dp"
                android:background="?attr/colorSurface"
                android:textColor="?android:attr/textColorPrimary" />

            <Button
                android:id="@+id/calendarViewButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Calendar"
                android:layout_marginStart="4dp"
                android:background="?attr/colorSurface"
                android:textColor="?android:attr/textColorPrimary" />

        </LinearLayout>

        <!-- View Type Text -->
        <TextView
            android:id="@+id/viewTypeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily View"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="8dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Add Event Button -->
        <Button
            android:id="@+id/addEventButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Event"
            android:textStyle="bold"
            android:backgroundTint="@color/teal_700" />

    </LinearLayout>

    <!-- Calendar View (initially hidden) -->
    <CalendarView
        android:id="@+id/calendarView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="?attr/colorSurface"
        android:layout_margin="8dp" />

    <!-- Events Container -->
    <LinearLayout
        android:id="@+id/eventsContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Events Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Schedule"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Time Slots Container (for daily view) -->
        <ScrollView
            android:id="@+id/timeSlotsContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Time slots will be added here dynamically -->
                
            </LinearLayout>
        </ScrollView>

        <!-- Events RecyclerView (for weekly view) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/eventsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:padding="8dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout> 