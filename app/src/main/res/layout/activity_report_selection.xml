<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="?attr/actionBarSize"
    android:padding="16dp"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Spacer to avoid notch -->
        <View
            android:id="@+id/statusSpacer"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent" />

        <!-- Welcome Message -->
        <TextView
            android:id="@+id/welcomeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Report"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Reports -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reports"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:textColor="?android:attr/textColorPrimary" />

        <Button
            android:id="@+id/buttonCreateReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Service Report"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/buttonGenericReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="General Report"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/buttonActionForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Action Form"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <!-- Quotations -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quotations"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:textColor="?android:attr/textColorPrimary" />

        <!-- Renamed: General Quotes -> Contract Quotations (contains 4/6/8/12 + Custom Quote inside) -->
        <Button
            android:id="@+id/buttonCreateQuotation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Contract Quotations"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/buttonCreateBirdQuotation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Bird Quote"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/buttonCreateGeneralQuotation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/custom_quote_button"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/buttonGeneralQuotationCatalog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/general_quotation_button"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <!-- Agreements & Compliance -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agreements &amp; Compliance"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:textColor="?android:attr/textColorPrimary" />

        <Button
            android:id="@+id/buttonServiceAgreements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Service Agreements"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/buttonEra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="ERA"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <!-- Templates -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Templates"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:textColor="?android:attr/textColorPrimary" />

        <Button
            android:id="@+id/buttonCustomReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Custom Template"
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/buttonCreateCustomReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Create Custom Report"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
