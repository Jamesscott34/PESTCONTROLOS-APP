<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/welcome_margin_top">

            <TextView
                android:id="@+id/employeeManagementTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Super Admin"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/button_spacing" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorSurface"
                android:padding="12dp"
                android:layout_marginBottom="@dimen/button_spacing">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BUG REPORTS / FEATURES"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/buttonManageBugReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Check bug reports or feature requests"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/buttonCreateFeature"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Feature"
                    android:backgroundTint="?attr/colorSecondary"
                    android:textColor="?attr/colorOnSecondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorSurface"
                android:padding="12dp"
                android:layout_marginBottom="@dimen/button_spacing">

                <TextView
                    android:id="@+id/initializeProfileLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="INITIALIZE PROFILE"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <Button
                    android:id="@+id/buttonToggleInitializeProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Initialize Profile ▼" />

                <LinearLayout
                    android:id="@+id/initializeProfileFormContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/editInitializeEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email"
                        android:inputType="textEmailAddress" />

                    <EditText
                        android:id="@+id/editInitializePassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        android:inputType="textPassword" />

                    <EditText
                        android:id="@+id/editInitializedUid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="UID will appear here"
                        android:focusable="false"
                        android:clickable="false"
                        android:inputType="textNoSuggestions" />

                    <Button
                        android:id="@+id/buttonInitializeProfile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Initialize Profile"
                        android:layout_marginTop="@dimen/button_spacing" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorSurface"
                android:padding="12dp"
                android:layout_marginBottom="@dimen/button_spacing">

                <TextView
                    android:id="@+id/createEmployeeLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CREATE EMPLOYEE"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <Button
                    android:id="@+id/buttonToggleCreateEmployee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Employee ▼" />

                <LinearLayout
                    android:id="@+id/createEmployeeFormContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/editEmployeeUid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="UID"
                        android:inputType="textNoSuggestions" />

                    <EditText
                        android:id="@+id/editEmployeeName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Name" />

                    <EditText
                        android:id="@+id/editEmployeeNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mobile number"
                        android:inputType="phone" />

                    <Spinner
                        android:id="@+id/spinnerEmployeeRole"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" />

                    <EditText
                        android:id="@+id/editEmployeeStaffId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Staff ID (e.g. 001)" />

                    <EditText
                        android:id="@+id/editEmployeeContractKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Contract key (lowercase)"
                        android:inputType="textNoSuggestions" />

                    <EditText
                        android:id="@+id/editEmployeeTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Title (optional)" />

                    <Button
                        android:id="@+id/buttonCreateEmployee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Create Employee"
                        android:layout_marginTop="@dimen/button_spacing" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:padding="12dp"
        android:layout_marginTop="@dimen/button_spacing">

        <TextView
            android:id="@+id/employeeListLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMPLOYEES"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <ListView
            android:id="@+id/employeeListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:scrollbars="vertical" />
    </LinearLayout>
</LinearLayout>
