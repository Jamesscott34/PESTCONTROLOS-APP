<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Support phones and tablets; layout-sw600dp used for 7"+ screens -->
    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:anyDensity="true" />

    <!-- ============================================================================
         GRPest Control Application - Android Manifest
         ============================================================================
         
         This manifest file defines the application's permissions, activities, and services.
         It configures the app for pest control business operations including:
         - Report generation and storage
         - Contract and customer management
         - Job assignment and tracking
         - File sharing and external storage access
         - Push notifications for real-time updates
         - Calendar integration for scheduling
         ============================================================================ -->

    <!-- ============================================================================
         APPLICATION PERMISSIONS
         ============================================================================
         These permissions enable the app's core functionalities:
         ============================================================================ -->
    
    <!-- Internet access for Firebase operations and web services -->
    <uses-permission android:name="android.permission.INTERNET"/>
    
    <!-- Network state access for offline/online mode detection -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Location (for admin location finder; tech devices publish last known location) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    
    <!-- External storage: save reports locally; read for viewing reports on device (incl. offline flavor) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    
    <!-- Push notification permissions for job updates and communications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    
    <!-- Account access for user authentication and profile management -->
    <uses-permission android:name="android.permission.GET_ACCOUNTS"/>
    
    <!-- Calendar permissions for job scheduling and appointment tracking -->
    <uses-permission android:name="android.permission.READ_CALENDAR"/>
    <uses-permission android:name="android.permission.WRITE_CALENDAR"/>
    
    <!-- Voice recognition permission for dictation feature -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    


    <!-- ============================================================================
         APPLICATION CONFIGURATION
         ============================================================================
         Main application settings and theme configuration
         ============================================================================ -->
    <application
        android:name="com.grpc.grpc.core.GrpcApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Grpc"
        tools:targetApi="31">

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- ============================================================================
             ACTIVITY DECLARATIONS
             ============================================================================
             Each activity represents a different screen or functionality in the app
             ============================================================================ -->

        <!-- Login Activity - Entry point for user authentication -->
        <activity
            android:name="com.grpc.grpc.login.LoginActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Main Activity - Central hub with navigation to all features -->
        <activity
            android:name="com.grpc.grpc.main.MainActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Admin dashboard: contracts/users summaries (admin + super_admin) -->
        <activity
            android:name="com.grpc.grpc.admin.ui.AdminDashboardActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name="com.grpc.grpc.billing.ui.InvoiceListActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name="com.grpc.grpc.billing.ui.CreateInvoiceActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name="com.grpc.grpc.email.ui.EmailComposeActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Super admin only: employee creation and profile initialization -->
        <activity
            android:name="com.grpc.grpc.admin.ui.EmployeeManagementActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name="com.grpc.grpc.admin.ui.EditEmployeeActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name="com.grpc.grpc.routes.ui.RouterActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name="com.grpc.grpc.routes.ui.CreatedRoutesActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Bug report / Feature request (admin): submit and view; super_admin: set cost & days -->
        <activity
            android:name="com.grpc.grpc.bugreport.ui.BugReportFeatureRequestSubmitActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />
        <activity
            android:name="com.grpc.grpc.bugreport.ui.BugReportFeatureRequestViewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Admin-only (for now): Global search entry point -->
        <activity
            android:name="com.grpc.grpc.search.ui.SearchActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Admin-only: view last known technician locations -->
        <activity
            android:name="com.grpc.grpc.location.ui.LocationFinderActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Help / README Activity - In-app instructions for using the app -->
        <activity
            android:name="com.grpc.grpc.files.ui.HelpReadmeActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Work View Activity - Calendar and work scheduling -->
        <activity
            android:name="com.grpc.grpc.workview.ui.WorkViewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- WorkView home screen widget: shows next 3 jobs from local cache, tap opens WorkViewActivity -->
        <receiver
            android:name="com.grpc.grpc.workview.ui.WorkViewWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/workview_widget_info"/>
        </receiver>

        <!-- Add Job From Calendar Activity -->
        <activity
            android:name="com.grpc.grpc.jobs.ui.AddJobFromCalendarActivity"
            android:windowSoftInputMode="adjustResize|stateHidden"
            android:exported="true"/>

        <!-- Add Follow-up Activity -->
        <activity
            android:name="com.grpc.grpc.reports.ui.AddFollowUpActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             REPORT MANAGEMENT ACTIVITIES
             ============================================================================
             Activities for creating, viewing, and managing pest control reports
             ============================================================================ -->

        <!-- Core report creation and management -->
        <activity
            android:name="com.grpc.grpc.reports.ui.ReportActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>
        <activity
            android:name="com.grpc.grpc.reports.ui.ReportPreviewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Offline PDF template settings (logo, watermark, header blocks) -->
        <activity
            android:name="com.grpc.grpc.reports.ui.PdfTemplateSettingsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity
            android:name="com.grpc.grpc.reports.ui.ViewTemplatesActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity
            android:name="com.grpc.grpc.reports.ui.ReportViewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <activity
            android:name="com.grpc.grpc.reports.ui.CreateReportActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Report selection and PDF management -->
        <activity
            android:name="com.grpc.grpc.reports.ui.ReportSelectionActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <activity
            android:name="com.grpc.grpc.safety.ui.SafetyStatementActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity
            android:name="com.grpc.grpc.reports.ui.PDFSelectionActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Action Form creation -->
        <activity
            android:name="com.grpc.grpc.reports.ui.ActionFormActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Signature Capture -->
        <activity
            android:name="com.grpc.grpc.core.SignatureCaptureActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Quotation viewing and management -->
        <activity
            android:name="com.grpc.grpc.quotations.ui.QuotationViewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Follow-up report creation -->
        <activity
            android:name="com.grpc.grpc.reports.ui.FollowUpActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Bird control quotation generation -->
        <activity
            android:name="com.grpc.grpc.quotations.ui.BirdQuotationActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             CONTRACT & CUSTOMER MANAGEMENT ACTIVITIES
             ============================================================================
             Activities for managing service contracts and customer relationships
             ============================================================================ -->

        <!-- Contract management and overview -->
        <activity
            android:name="com.grpc.grpc.contracts.ui.ContractsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Individual contract viewing and editing -->
        <activity
            android:name="com.grpc.grpc.contracts.ui.ViewContractActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- New contract creation -->
        <activity
            android:name="com.grpc.grpc.contracts.ui.AddContractActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             QUOTATION & SERVICE AGREEMENT ACTIVITIES
             ============================================================================
             Activities for generating quotes and service agreements
             ============================================================================ -->

        <!-- Quotation management and generation -->
        <activity
            android:name="com.grpc.grpc.quotations.ui.QuotesActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Service agreement creation and management -->
        <activity
            android:name="com.grpc.grpc.serviceagreements.ui.ServiceAgreementActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Service agreement viewing -->
        <activity android:name="com.grpc.grpc.serviceagreements.ui.ServiceAgreementViewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             GENERAL REPORT ACTIVITIES (Different Point Sizes)
             ============================================================================
             Activities for creating reports with different formatting options
             ============================================================================ -->

        <!-- General reports with different point sizes for various document types -->
        <activity
            android:name="com.grpc.grpc.generalreports.ui.General8ptActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <activity
            android:name="com.grpc.grpc.generalreports.ui.General6ptActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <activity
            android:name="com.grpc.grpc.generalreports.ui.General4ptActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <activity
            android:name="com.grpc.grpc.generalreports.ui.General12ptActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             SALES & LEAD MANAGEMENT ACTIVITIES
             ============================================================================
             Activities for managing sales leads and commission tracking
             ============================================================================ -->

        <!-- Lead management and selection -->
        <activity
            android:name="com.grpc.grpc.leads.ui.LeadsSelectionActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Lead viewing and management -->
        <activity
            android:name="com.grpc.grpc.leads.ui.ViewLeadsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Lead generation and creation -->
        <activity
            android:name="com.grpc.grpc.leads.ui.GenerateLeadsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             JOB MANAGEMENT ACTIVITIES
             ============================================================================
             Activities for job assignment, tracking, and management
             ============================================================================ -->

        <!-- Job overview and management -->
        <activity
            android:name="com.grpc.grpc.jobs.ui.JobsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- New job creation -->
        <activity
            android:name="com.grpc.grpc.jobs.ui.AddJobsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Individual job viewing and editing -->
        <activity
            android:name="com.grpc.grpc.jobs.ui.ViewJobActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             RODENT CONTROL ACTIVITIES
             ============================================================================
             Specialized activities for rodent control operations
             ============================================================================ -->

        <!-- Rodent control routine operations -->
        <activity android:name="com.grpc.grpc.jobs.rodent.RodentRoutineActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- External rodent routine operations -->
        <activity android:name="com.grpc.grpc.jobs.rodent.RodentActivityExternalRoutine"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- External rodent call-out operations -->
        <activity android:name="com.grpc.grpc.jobs.rodent.RodentCallOutExternalActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Rodent call-out operations -->
        <activity android:name="com.grpc.grpc.jobs.rodent.RodentCallOutActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Initial rodent control operations -->
        <activity android:name="com.grpc.grpc.jobs.rodent.RodentInitialActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Rodent routine activity management -->
        <activity android:name="com.grpc.grpc.jobs.rodent.RodentActivityRoutine"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Rodent job activity management -->
        <activity android:name="com.grpc.grpc.jobs.rodent.RodentJobActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- ============================================================================
             FILE MANAGEMENT & STORAGE ACTIVITIES
             ============================================================================
             Activities for managing stored files and reports
             ============================================================================ -->

        <!-- Folder contents viewing -->
        <activity android:name="com.grpc.grpc.files.ui.FolderContentsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Stored reports management -->
        <activity android:name="com.grpc.grpc.reports.ui.StoredReportsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <activity
            android:name="com.grpc.grpc.reports.ui.CloudStorageBrowserActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity
            android:name="com.grpc.grpc.converter.ui.ConverterActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity
            android:name="com.grpc.grpc.pdfeditor.PdfEditorActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- ============================================================================
             COMMUNICATION & MESSAGING ACTIVITIES
             ============================================================================
             Activities for internal communication and messaging
             ============================================================================ -->

        <!-- Messaging - conversation list -->
        <activity android:name="com.grpc.grpc.messaging.ui.NotificationsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>
        <activity
            android:name=".messaging.ui.NotificationPreferencesActivity"
            android:exported="false"
            android:label="Notification Preferences" />
        <activity android:name="com.grpc.grpc.messaging.ui.MessagingConversationsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Internal messaging - per-conversation chat -->
        <activity android:name="com.grpc.grpc.messaging.ui.MessagingActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             QUOTATION & GENERAL REPORTS ACTIVITIES
             ============================================================================
             Activities for quotation generation and general reporting
             ============================================================================ -->

        <!-- General quotation creation -->
        <activity android:name="com.grpc.grpc.quotations.ui.GeneralQuotationActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- General Quotation from catalog (sales.json per flavor) -->
        <activity android:name="com.grpc.grpc.quotations.ui.GeneralQuotationFromCatalogActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- ============================================================================
             ENVIRONMENTAL RISK ASSESSMENT (ERA) ACTIVITIES
             ============================================================================
             Activities for environmental compliance and risk assessments
             ============================================================================ -->

        <!-- ERA selection and management -->
        <activity android:name="com.grpc.grpc.era.ui.EnvironmentSelectionActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Non-toxic ERA creation -->
        <activity android:name="com.grpc.grpc.era.ui.NonToxERAActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Toxic ERA creation -->
        <activity android:name="com.grpc.grpc.era.ui.ToxicERAActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Bird proofing ERA creation -->
        <activity android:name="com.grpc.grpc.era.ui.BirdProofingERAActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ERA viewing and management -->
        <activity android:name="com.grpc.grpc.era.ui.ERAViewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             GENERAL REPORT & MANAGEMENT ACTIVITIES
             ============================================================================
             Activities for general reporting and management tasks
             ============================================================================ -->

        <!-- General report creation -->
        <activity android:name="com.grpc.grpc.generalreports.ui.GeneralReportActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Management job creation -->
        <activity android:name="com.grpc.grpc.jobs.ui.AddManagmentJobsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Management job viewing -->
        <activity android:name="com.grpc.grpc.jobs.ui.ViewManagmentJobActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- ============================================================================
             CONTRACT REPORT & BEHINDS LIST ACTIVITIES
             ============================================================================
             Activities for contract-specific reports and overdue contract management
             ============================================================================ -->

        <!-- Behinds list viewing and management -->
        <activity android:name="com.grpc.grpc.contracts.ui.BehindsListViewActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Contract-specific report viewing -->
        <activity android:name="com.grpc.grpc.contracts.ui.ContractReportsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"/>

        <!-- Maps placeholder entry from View Contract -->
        <activity android:name="com.grpc.grpc.maps.ui.MapsPlaceholderActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity android:name="com.grpc.grpc.maps.ui.SiteMapEditorActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <activity android:name="com.grpc.grpc.maps.ui.MapsListActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- ============================================================================
             FIREBASE CLOUD MESSAGING SERVICE
             ============================================================================
             Service for handling push notifications and real-time messaging
             ============================================================================ -->
        <service
            android:name="com.grpc.grpc.messaging.service.FirebaseMessagingServiceGRPC"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ============================================================================
             FILE PROVIDER CONFIGURATION
             ============================================================================
             Enables secure file sharing between app components and external apps
             ============================================================================ -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:grantUriPermissions="true"
            android:exported="false">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/filepaths"/>
        </provider>



    </application>
</manifest>
